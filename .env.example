# === API Keys ===
FIREWORKS_API_KEY=your_fireworks_api_key
WHISK_COOKIE=your_whisk_cookie
PEXELS_API_KEY=your_pexels_api_key
UNSPLASH_API_KEY=your_unsplash_api_key
PIXABAY_API_KEY=your_pixabay_api_key
BING_API_KEY=your_bing_api_key
SERPAPI_KEY=your_serpapi_key
INWORLD_UID=your_inworld_uid

# === LLM ===
LLM_MODEL=accounts/fireworks/models/qwen3p6-plus
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
DEFAULT_LANGUAGE=en

# === Vision (Qwen VL) ===
VISION_MODEL=accounts/fireworks/models/qwen3p6-plus
VALIDATOR_CONFIDENCE_THRESHOLD=0.6
VALIDATOR_MAX_ATTEMPTS=5

# === Image Generation (Whisk/Imagen) ===
IMAGE_MODEL=IMAGEN_3_5
IMAGE_ASPECT_RATIO=IMAGE_ASPECT_RATIO_LANDSCAPE
IMAGE_SEED=0
IMAGE_COUNT=1

# === TTS (InWorld) ===
TTS_SAMPLE_RATE=48000
TTS_MAX_CHARS=1000
TTS_DEFAULT_VOICE_ID=Blake
TTS_MODEL_ID=inworld-tts-1.5-max
TTS_COOKIE=your_inworld_session_cookie

# === Upscaler (ESRGAN + SD img2img) ===
UPSCALER_MODEL=4x-ultrasharp
UPSCALER_MODEL_PATH=
UPSCALER_SCALE=2
UPSCALER_TILE=512
UPSCALER_GPU_ID=0
UPSCALER_HALF=true
UPSCALER_GFPGAN=
UPSCALER_MODEL_DIR=
UPSCALER_SD_CHECKPOINT=E:\coding\pyttsscraper\app\models\dreamshaperXL_lightningDPMSDE.safetensors
UPSCALER_SD_PROMPT=highly detailed vibrant colors, 4k
UPSCALER_SD_NEGATIVE=low quality, blurry, jpeg artifacts, noise, grain, oversharpened, artifacts, deformed
UPSCALER_SD_STRENGTH=0.13
UPSCALER_SD_STEPS=6
UPSCALER_SD_GUIDANCE=2.0
UPSCALER_SD_SAMPLER=DPM++ SDE Karras
UPSCALER_SD_VAE=
