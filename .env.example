# === API Keys ===
FIREWORKS_API_KEY=your_fireworks_api_key
WHISK_COOKIE=your_whisk_cookie
PEXELS_API_KEY=your_pexels_api_key
UNSPLASH_API_KEY=your_unsplash_api_key
PIXABAY_API_KEY=your_pixabay_api_key
BING_API_KEY=your_bing_api_key
SERPAPI_KEY=your_serpapi_key
INWORLD_UID=your_inworld_uid

# === LLM ===
LLM_MODEL=accounts/fireworks/models/qwen3p6-plus
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
DEFAULT_LANGUAGE=en

# === Vision (Qwen VL) ===
VISION_MODEL=accounts/fireworks/models/qwen3p6-plus
VALIDATOR_CONFIDENCE_THRESHOLD=0.6
VALIDATOR_MAX_ATTEMPTS=5

# === Image Generation (Whisk/Imagen) ===
IMAGE_MODEL=IMAGEN_3_5
IMAGE_ASPECT_RATIO=IMAGE_ASPECT_RATIO_LANDSCAPE
IMAGE_SEED=0
IMAGE_COUNT=1

# === TTS (InWorld) ===
TTS_SAMPLE_RATE=48000
TTS_MAX_CHARS=1000
TTS_DEFAULT_VOICE_ID=Blake
TTS_MODEL_ID=inworld-tts-1.5-max
